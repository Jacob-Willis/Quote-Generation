@page "/"
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<h1>Quote Generator</h1>

<button class="btn btn-primary mb-3"  @onclick="GenerateQuote">Generate Quote</button>

<table class="table table-striped">
    <thead>
        <tr>
            @* <th>#</th> *@
            <th>Author</th>
            <th>Quote</th>
        </tr>
    </thead>
    <tbody>
        <tr>
            @* <td>1</td> *@
            <td>@Author</td>
            <td>@Quote</td>
        </tr>
    </tbody>
</table>